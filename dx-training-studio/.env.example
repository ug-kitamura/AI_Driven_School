# Copy to .env.local and fill in values.
# Used when the settings dialog leaves API keys empty (dialog values take priority).

# AI API key
# see https://console.anthropic.com/settings/keys
AI_API_KEY=sk-ant-xxxxx-xxxxxxxxxxxxxxxxxxxxxxxxx

# Pixabay API key
# see https://pixabay.com/api/docs/
PIXABAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Blob read-write token (storage mode for canonical images)
# Create a Private Blob store in Vercel Dashboard and copy BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
